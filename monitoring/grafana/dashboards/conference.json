          "legendFormat": "Session p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{service=\"session-service\"}[5m])) by (le))",
          "legendFormat": "Session p99",
          "refId": "C"
