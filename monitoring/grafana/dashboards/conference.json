      "title": "HTTP 응답시간 p95 (목표: <100ms)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{service=\"session-service\"}[5m])) by (le))",
          "legendFormat": "Session p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
